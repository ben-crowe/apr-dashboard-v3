        }

        .content {
            width: 100%;
            min-height: calc(100% - 60px);
            padding-bottom: 60px;
        }

        h1 {
            font-size: 14px;
            font-weight: bold;
            margin-bottom: 12px;
            padding-bottom: 6px;
            border-bottom: 2px solid #003366;
            color: #003366;
        }

        ul {
