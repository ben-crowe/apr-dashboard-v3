-- Create secure RLS policies for job_documents (with user_id)
CREATE POLICY "Users can view their job documents" 
ON public.job_documents 
FOR SELECT 
TO authenticated 
USING (auth.uid() = user_id);

CREATE POLICY "Users can create their job documents" 
ON public.job_documents 
FOR INSERT 
TO authenticated 
WITH CHECK (auth.uid() = user_id);

CREATE POLICY "Users can update their job documents" 
ON public.job_documents 
