        .footer {
            margin-top: auto;
            padding-top: 20px;
            border-top: 2px solid #0066cc;
            font-size: 10px;
            color: #666;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .page-number {
            text-align: center;
            width: 100%;
        }
    </style>
</head>
