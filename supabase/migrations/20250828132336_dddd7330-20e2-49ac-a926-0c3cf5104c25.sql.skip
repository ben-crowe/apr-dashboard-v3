-- Fix critical security issues with job-related tables

-- First, enable RLS on tables that don't have it
ALTER TABLE public.conversation_chunks ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.conversations ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.files_modified ENABLE ROW LEVEL SECURITY;
ALTER TABLE public.job_documents ENABLE ROW LEVEL SECURITY;

-- Add user_id columns to track ownership for job-related tables
ALTER TABLE public.job_submissions ADD COLUMN IF NOT EXISTS user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE;
ALTER TABLE public.job_documents ADD COLUMN IF NOT EXISTS user_id UUID REFERENCES auth.users(id) ON DELETE CASCADE;

-- Drop existing overly permissive policies
DROP POLICY IF EXISTS "Enable all operations for authenticated users" ON public.job_submissions;
DROP POLICY IF EXISTS "Enable all operations for authenticated users" ON public.job_loe_details;
DROP POLICY IF EXISTS "Enable all operations for authenticated users" ON public.job_property_info;
DROP POLICY IF EXISTS "Enable all operations for authenticated users" ON public.job_files;

-- Create secure RLS policies for job_submissions
CREATE POLICY "Users can view their own job submissions" 
ON public.job_submissions 
FOR SELECT 
TO authenticated 
USING (auth.uid() = user_id);

CREATE POLICY "Users can create their own job submissions" 
ON public.job_submissions 
FOR INSERT 
TO authenticated 
WITH CHECK (auth.uid() = user_id);

CREATE POLICY "Users can update their own job submissions" 
ON public.job_submissions 
FOR UPDATE 
TO authenticated 
USING (auth.uid() = user_id)
WITH CHECK (auth.uid() = user_id);

CREATE POLICY "Users can delete their own job submissions" 
ON public.job_submissions 
FOR DELETE 
TO authenticated 
USING (auth.uid() = user_id);

-- Create secure RLS policies for job_loe_details (linked via job_submissions)
CREATE POLICY "Users can view LOE details for their jobs" 
ON public.job_loe_details 
FOR SELECT 
TO authenticated 
USING (
  EXISTS (
    SELECT 1 FROM public.job_submissions 
    WHERE id = job_loe_details.job_id 
    AND user_id = auth.uid()
  )
);

CREATE POLICY "Users can create LOE details for their jobs" 
ON public.job_loe_details 
FOR INSERT 
TO authenticated 
WITH CHECK (
  EXISTS (
    SELECT 1 FROM public.job_submissions 
    WHERE id = job_loe_details.job_id 
    AND user_id = auth.uid()
  )
);

CREATE POLICY "Users can update LOE details for their jobs" 
ON public.job_loe_details 
FOR UPDATE 
TO authenticated 
USING (
  EXISTS (
    SELECT 1 FROM public.job_submissions 
    WHERE id = job_loe_details.job_id 
    AND user_id = auth.uid()
  )
)
WITH CHECK (
  EXISTS (
    SELECT 1 FROM public.job_submissions 
    WHERE id = job_loe_details.job_id 
    AND user_id = auth.uid()
  )
);

CREATE POLICY "Users can delete LOE details for their jobs" 
ON public.job_loe_details 
FOR DELETE 
TO authenticated 
USING (
  EXISTS (
    SELECT 1 FROM public.job_submissions 
    WHERE id = job_loe_details.job_id 
    AND user_id = auth.uid()
  )
);

