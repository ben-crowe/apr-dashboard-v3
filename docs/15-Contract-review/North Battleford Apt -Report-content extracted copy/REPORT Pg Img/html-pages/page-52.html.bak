                        <td class="numeric">$82,827</td>
                        <td class="numeric">$189,400</td>
                        <td class="numeric">$214,375</td>
                    </tr>
                    <tr>
                        <td class="data-row-label">NOI/Unit</td>
                        <td class="numeric">$7,780.02</td>
