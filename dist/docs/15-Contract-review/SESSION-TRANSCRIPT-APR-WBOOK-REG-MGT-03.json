lue={expPayroll}\n   409\t                  onChange={e => updateField('calc-exp-payroll', e.target.value)}\n   410\t                  className=\"h-6 w-16 text-right text-xs p-1\"\n   411\t                  style={inputStyle}\n   412\t                />\n   413\t              </td>\n   414\t              <td className=\"px-2 py-1\" style={{ color: colors.textDim }}>/unit</td>\n   415\t              <td className=\"px-2 py-1 text-right\" style={{ color: colors.textMuted }}>{formatCurrency(expPayroll * totalUnits)}</td>\n   416\t            </tr>\n   417\t            <tr style={{ borderBottom: `1px solid ${colors.border}` }}>\n   418\t              <td className=\"px-2 py-1\" style={{ color: colors.textMuted }}>Other</td>\n   419\t              <td className=\"px-2 py-1\">\n   420\t                <Input\n   421\t                  type=\"number\"\n   422\t                  value={expOther}\n   423\t                  onChange={e => updateField('calc-exp-other', e.target.value)}\n   424\t                  className=\"h-6 w-16 text-right text-xs p-1\"\n   425\t                  style={inputStyle}\n   426\t                />\n   427\t              </td>\n   428\t              <td className=\"px-2 py-1\" style={{ color: colors.textDim }}>/unit</td>\n   429\t              <td className=\"px-2 py-1 text-right\" style={{ color: colors.textMuted }}>{formatCurrency(expOther * totalUnits)}</td>\n   430\t            </tr>\n   431\t          </tbody>\n   432\t          <tfoot style={{ borderTop: `1px solid ${colors.border}` }}>\n   433\t            <tr>\n   434\t              <td className=\"px-2 py-1\" style={{ color: colors.textMuted }} colSpan={3}>Total Expenses ({formatNumber(expenseRatio)}%)</td>\n   435\t              <td className=\"px-2 py-1 text-right\" style={{ color: colors.textMuted }}>({formatCurrency(expensesTotal)})</td>\n   436\t            </tr>\n   437\t          </tfoot>\n   438\t        </table>\n   439\t      </div>\n   440\t\n   441\t      {/* NOI */}\n   442\t      <div className=\"rounded-sm px-3 py-2 flex justify-between\" style={{ border: `1px solid ${colors.border}` }}>\n   443\t        <span style={{ color: colors.textMuted }}>Net Operating Income (NOI)</span>\n   444\t        <span className=\"font-medium\" style={{ color: colors.text }}>{formatCurrency(noi)}</span>\n   445\t      </div>\n   446\t\n   447\t      {/* CAP RATE & VALUE */}\n   448\t      <div className=\"rounded-sm overflow-hidden\" style={{ border: `1px solid ${colors.border}` }}>\n   449\t        <div className=\"px-2 py-1.5\" style={{ borderBottom: `1px solid ${colors.border}` }}>\n   450\t          <span className=\"text-[10px] font-medium uppercase tracking-wider\" style={{ color: colors.textMuted }}>{`Capitalization`}</span>\n   451\t        </div>\n   452\t        <table className=\"w-full\">\n   453\t          <tbody>\n   454\t            <tr style={{ borderBottom: `1px solid ${colors.border}` }}>\n   455\t              <td className=\"px-2 py-1\" style={{ color: colors.textMuted }}>Cap Rate</td>\n   456\t              <td className=\"px-2 py-1\">\n   457\t                <Input\n   458\t                  type=\"number\"\n   459\t                  step=\"0.25\"\n   460\t                  value={capRate}\n   461\t                  onChange={e => updateField('calc-cap-rate', e.target.value)}\n   462\t                  className=\"h-6 w-16 text-right text-xs p-1\"\n   463\t                  style={inputStyle}\n   464\t                />\n   465\t              </td>\n   466\t              <td className=\"px-2 py-1\" style={{ color: colors.textDim }}>%</td>\n   467\t              <td className=\"px-2 py-1\"></td>\n   468\t            </tr>\n   469\t            <tr style={{ borderBottom: `1px solid ${colors.border}` }}>\n   470\t              <td className=\"px-2 py-1\" style={{ color: colors.textMuted }} colSpan={3}>Raw Value (NOI \u00f7 Cap Rate)</td>\n   471\t              <td className=\"px-2 py-1 text-right\" style={{ color: colors.textMuted }}>{formatCurrency(rawValue)}</td>\n   472\t            </tr>\n   473\t            <tr>\n   474\t              <td className=\"px-2 py-1\" style={{ color: colors.textMuted }} colSpan={3}>Rounded (to $10,000)</td>\n   475\t              <td className=\"px-2 py-1 text-right\" style={{ color: colors.textMuted }}>{formatCurrency(roundedValue)}</td>\n   476\t            </tr>\n   477\t          </tbody>\n   478\t        </table>\n   479\t      </div>\n   480\t\n   481\t      {/* FINAL VALUE - The ONE accent */}\n   482\t      <div className=\"rounded-sm px-3 py-3\" style={{ border: `1px solid ${colors.border}`, backgroundColor: colors.panelBgAlt }}>\n   483\t        <div className=\"flex justify-between items-center\">\n   484\t          <span style={{ color: colors.textMuted }}>Indicated Value</span>\n   485\t          <span className=\"text-xl font-semibold\" style={{ color: colors.text }}>{formatCurrency(indicatedValue)}</span>\n   486\t        </div>\n   487\t        {totalUnits > 0 && (\n   488\t          <div className=\"text-[10px] mt-1 text-right\" style={{ color: colors.textDim }}>\n   489\t            {formatCurrency(indicatedValue / totalUnits)}/unit \u00b7 ${formatNumber(indicatedValue / totalSf)}/SF\n   490\t          </div>\n   491\t        )}\n   492\t      </div>\n   493\t\n   494\t    </div>\n   495\t  );\n   496\t}\n   497\t",
