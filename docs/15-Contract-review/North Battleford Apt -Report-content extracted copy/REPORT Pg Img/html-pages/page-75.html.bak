            font-weight: bold;
        }

        .footer {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            font-size: 10px;
            color: #666;
            padding: 10px 0.5in;
            text-align: right;
            border-top: 1px solid #ddd;
            background: white;
        }

