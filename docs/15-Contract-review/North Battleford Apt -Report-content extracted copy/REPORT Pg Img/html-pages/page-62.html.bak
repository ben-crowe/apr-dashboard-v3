            height: 140px;
            background-color: #cccccc;
            border: 2px dashed #999999;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #666;
            font-size: 12px;
            text-align: center;
        }

        .remarks {
            font-size: 10px;
            line-height: 1.4;
            color: #333;
        }

        .remarks-title {
            font-size: 12px;
            font-weight: bold;
            margin-bottom: 8px;
            border-bottom: 1px solid #000;
            padding-bottom: 5px;
