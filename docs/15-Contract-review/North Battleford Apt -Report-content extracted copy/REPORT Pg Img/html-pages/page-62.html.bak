            font-size: 11px;
            color: #666;
            margin-top: 2px;
        }

        .content {
            display: flex;
            gap: 20px;
            flex: 1;
        }

        .left-column {
            flex: 1;
        }

        .right-column {
            width: 280px;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .section {
            margin-bottom: 20px;
        }

        .section-title {
            font-size: 12px;
            font-weight: bold;
            color: #000;
            border-bottom: 1px solid #000;
            padding-bottom: 5px;
            margin-bottom: 10px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
            margin-bottom: 10px;
        }

        table tr {
            border-bottom: 1px solid #e0e0e0;
        }

        table td {
            padding: 5px 8px;
            vertical-align: top;
        }

        table td:first-child {
            width: 60%;
            font-weight: 500;
            color: #333;
        }

        table td:last-child {
            text-align: right;
            color: #333;
        }

        .value-positive {
            color: #006600;
        }

        .value-negative {
            color: #cc0000;
        }

        .photo-placeholder {
            width: 100%;
            height: 180px;
            background-color: #cccccc;
            border: 2px dashed #999999;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #666;
            font-size: 12px;
            text-align: center;
            margin-bottom: 10px;
        }

        .map-placeholder {
