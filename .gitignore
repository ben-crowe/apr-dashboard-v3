# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
# Ignore dist except docs folder
dist/*
!dist/docs/
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Build and cache directories
.next/
.nuxt/
.cache/
.parcel-cache/
.vite/

# Database and backup files
*.sql
*.db
*.sqlite
*.dump

# Migrations are source, not backups — the blanket *.sql above hid every new one
# from git, so schema changes existed only on the machine that applied them.
!supabase/migrations/*.sql

# Large/binary files
*.zip
*.tar.gz
*.rar
*.7z
.vercel

# Claude sessions (internal only)
.claude/sessions/

# Test screenshots
.playwright-mcp/
supabase/functions/.env

# Temp test data
*-logs.json
test-results.txt

# Credentials and sensitive test data
docs/03-ClickUp-Integration/20-VALCRE-CREDENTIALS.md
docs/03-ClickUp-Integration/28-RESEND-EMAIL-CREDENTIALS.md
credentials/
Password Manager/
*.json
!package.json
!package-lock.json
!tsconfig*.json
!eslint.config.js
# Deno config for the edge functions is SOURCE, not test data — without it the
# type-checker cannot resolve npm imports and silently checks nothing.
# Keep the blanket rule above: it deliberately hides live Valcre/ClickUp API
# dumps and credential files. Un-ignore config only, never a data directory.
!supabase/functions/deno.json
!supabase/functions/**/deno.json

# Gate contract artifact — the drift-check master config MUST ship (Vercel prod build reads it); committed like a lockfile
!docs/Features/08-Master-Field-Registry/GENERATED-v3-drift-check.json
.env.v4shoot
