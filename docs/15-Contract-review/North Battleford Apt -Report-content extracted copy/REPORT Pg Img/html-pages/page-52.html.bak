                        <td class="numeric">$1,500,000</td>
                        <td class="numeric">$3,650,000</td>
                        <td class="numeric">$4,200,000</td>
                    </tr>
                    <tr>
                        <td class="data-row-label">Price/SF</td>
                        <td class="numeric">$137</td>
                        <td class="numeric">$137</td>
                        <td class="numeric">$137</td>
                        <td class="numeric">$194</td>
