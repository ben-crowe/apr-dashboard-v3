            border-collapse: collapse;
            margin-bottom: 12px;
            font-size: 10px;
        }

        th {
            background-color: #e6e6e6;
            border: 1px solid #999;
            padding: 4px 6px;
            text-align: left;
            font-weight: bold;
            font-size: 10px;
        }

        td {
            border: 1px solid #ccc;
            padding: 4px 6px;
            text-align: left;
            vertical-align: top;
        }

        tr:nth-child(even) {
            background-color: #f9f9f9;
        }

        .numeric {
            text-align: right;
            font-family: 'Courier New', monospace;
        }

        .section-subheader {
