<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Page 12 - Introduction & Executive Summary</title>
  <style>
    @page {
      size: 8.5in 11in;
      margin: 0;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      width: 8.5in;
      height: 11in;
      padding: 0.5in;
      font-family: Arial, sans-serif;
      font-size: 11px;
      line-height: 1.4;
      color: #000;
      background: #fff;
    }

    .page {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: column;
    }

    .header {
      border-bottom: 3px solid #003d82;
      padding-bottom: 8px;
      margin-bottom: 20px;
    }

    .header h1 {
      font-size: 16px;
      font-weight: bold;
      color: #000;
    }

    .content {
      flex: 1;
    }

    .photo-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 30px;
    }

    .photo-item {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .photo-placeholder {
      width: 100%;
      aspect-ratio: 4/3;
      background: #cccccc;
      border: 1px solid #999;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #666;
      font-size: 11px;
      min-height: 120px;
    }

    .photo-label {
      font-size: 11px;
      font-weight: normal;
      color: #000;
      text-align: center;
    }

    .footer {
      margin-top: auto;
      padding-top: 20px;
      border-top: none;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      font-size: 9px;
      color: #333;
    }

    .footer-left {
      display: flex;
      gap: 4px;
    }

    .footer-accent {
      width: 40px;
      height: 8px;
      background: linear-gradient(90deg, #4a9fd8 0%, #003d82 100%);
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="header">
      <h1>Introduction & Executive Summary</h1>
    </div>

    <div class="content">
      <div class="photo-grid">
        <div class="photo-item">
          <div class="photo-placeholder">[PHOTO: Typical Bathroom]</div>
          <div class="photo-label">1121 - Typical Bathroom</div>
        </div>

        <div class="photo-item">
          <div class="photo-placeholder">[PHOTO: Typical Kitchen]</div>
          <div class="photo-label">1121 - Typical Kitchen</div>
        </div>

        <div class="photo-item">
          <div class="photo-placeholder">[PHOTO: Typical Bedroom]</div>
          <div class="photo-label">1121 - Typical Bedroom</div>
        </div>

        <div class="photo-item">
          <div class="photo-placeholder">[PHOTO: Laundry Room]</div>
          <div class="photo-label">1121 - Laundry Room</div>
        </div>

        <div class="photo-item">
          <div class="photo-placeholder">[PHOTO: Electrical Room]</div>
          <div class="photo-label">1121 - Electrical Room</div>
        </div>

        <div class="photo-item">
          <div class="photo-placeholder">[PHOTO: Typical Boiler]</div>
          <div class="photo-label">1121 - Typical Boiler</div>
        </div>
      </div>
    </div>

    <div class="footer">
      <div class="footer-left">
        <span>7&nbsp;&nbsp;&nbsp;1101, 1121 109 St. North Battleford, Saskatchewan | File VAL251012 - 1</span>
      </div>
      <div class="footer-accent"></div>
    </div>
  </div>
</body>
</html>