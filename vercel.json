{
  "functions": {
    "api/valcre.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/field-registry.html",
      "destination": "/field-registry.html"
    },
    {
      "source": "/field-registry-v5.html",
      "destination": "/field-registry-v5.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "framework": "vite"
}
